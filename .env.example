# 剧本分镜智能体配置示例。请复制此文件为.env并填入实际的API密钥
# 详细参考 Github: https://github.com/neopen

# ================= 应用配置 =================


# ================= API配置 =================
#  服务器主机，支持HOST环境变量
API__HOST=localhost
#  服务器端口，支持PORT环境变量
API__PORT=8000
#  工作进程数，支持WORKERS环境变量
# API__WORKERS=1
# API__RELOAD=true


########################## Redis 配置 ##########################
# Redis 单节点配置，支持使用完整的URL参数配置：REDIS_URL=redis://:password@localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# 连接池配置
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=20
REDIS_CONNECT_TIMEOUT=20
REDIS_RETRY_ON_TIMEOUT=true
REDIS_DECODE_RESPONSES=true

# 集群模式配置（如果需要）
# REDIS_CLUSTER=false
# REDIS_STARTUP_NODES=node1:7000,node2:7001,node3:7002

# SSL配置
# REDIS_SSL_CERT_REQS=required

########################## 注意事项 ##############################
# 1. 请确保设置有效的AI API密钥
# 2. 对于中文剧本，推荐使用支持中文的模型
# 3. 调试模式会记录详细日志，可能会包含敏感信息